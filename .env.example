# SQLite (default for local dev - no setup required)
DATABASE_URL="file:./dev.db"
# Or PostgreSQL: postgresql://user:password@localhost:5432/betting_forum?schema=public

# Required for sign-in to work. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
# Must match the URL you use in the browser (e.g. http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - for "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: NEXTAUTH_URL/api/auth/callback/google
# In PRODUCTION: add https://yourdomain.com/api/auth/callback/google in Google Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email verification (optional - for sending verification emails on signup)
# Get API key at https://resend.com - free tier available
RESEND_API_KEY=""
# Sender email - use a verified domain in Resend (or onboarding@resend.dev for testing)
EMAIL_FROM="onboarding@resend.dev"

# Claude API (required for "AI Complete" - write/complete product articles)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Cron secret for scheduled jobs. Generate with: openssl rand -hex 32
# Required in production for /api/cron/ai-bots and /api/cron/sports-digest (Vercel cron or external scheduler)
CRON_SECRET=""

# Optional: real-time odds feed (not wired yet; digests use Claude + web search until then)
# ODDS_API_KEY=""

# External API: post articles, products, bonuses, etc. from external sources (syndication, affiliates)
# Generate with: openssl rand -hex 32
EXTERNAL_API_KEY=""
# Username of the user that will be the author of API-submitted content. Create this user in admin first.
EXTERNAL_API_AUTHOR_USERNAME="api-external"
