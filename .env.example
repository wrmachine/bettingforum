# SQLite (default for local dev - no setup required)
DATABASE_URL="file:./dev.db"
# Or PostgreSQL: postgresql://user:password@localhost:5432/betting_forum?schema=public

# Required for sign-in to work. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
# Must match the URL you use in the browser (e.g. http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - for "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: NEXTAUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email verification (optional - for sending verification emails on signup)
# Get API key at https://resend.com - free tier available
RESEND_API_KEY=""
# Sender email - use a verified domain in Resend (or onboarding@resend.dev for testing)
EMAIL_FROM="onboarding@resend.dev"

# Claude API (required for "AI Complete" - write/complete product articles)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
